---
import { getCollection } from "astro:content";

import Items from "../components/Items.astro";
import CommonLayout from "../layouts/common.astro";
import "../styles/example-floors.css";

const entries = await getCollection("floormaps");

const items = entries
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .map((e) => ({
    href: `/demos/${e.data.mapId}/index.html`,
    title: e.data.title,
  }));
---

<CommonLayout title="svgmapviewer">
  <Items items={items} />
</CommonLayout>
